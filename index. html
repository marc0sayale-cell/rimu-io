//  ONBOARDING
// ═══════════════════════════════════════════════════════════════
function renderStep() {
  document.querySelectorAll('.obStep').forEach(s => s.classList.remove('on'));
  document.getElementById('os'+obStep).classList.add('on');
  const pct = Math.round((obStep/7)*100);
  document.getElementById('obFill').style.width = pct+'%';
  document.getElementById('obLbl').textContent  = `Passo ${obStep} de 7`;
  document.getElementById('obPct').textContent  = pct+'%';
  document.getElementById('obNx').textContent   = obStep===7 ? '🚀 Gerar meu plano!' : 'Continuar →';
}

function obNext() {
  if (obStep === 1) {
    const nome = (document.getElementById('ob_nome').value||'').trim();
    const sexo = document.getElementById('ob_sexo').value;
    const alt  = document.getElementById('ob_alt').value;
    if (!nome)                       { toast('Digite seu nome 😊'); return; }
    if (!sexo)                       { toast('Selecione seu sexo'); return; }
    if (!alt||+alt<100||+alt>250)    { toast('Digite sua altura em cm (ex: 175)'); return; }
  }
  if (obStep === 3 && !document.querySelector('#gOpts .opt.sel'))      { toast('Selecione seu objetivo 🎯'); return; }
  if (obStep === 4 && !document.querySelector('#lvlOpts .opt.sel'))    { toast('Selecione seu nível 💪'); return; }
  if (obStep === 5) {
    if (!document.querySelector('#localOpts .opt.sel'))  { toast('Selecione onde você treina 🏠'); return; }
    if (!document.querySelector('#frOpts .opt.sel'))     { toast('Selecione quantos dias 🏋️'); return; }
  }
  if (obStep === 6 && !document.querySelector('#dietOpts .opt.sel'))   { toast('Selecione sua dieta 🥗'); return; }
  if (obStep === 7 && !document.querySelector('#empOpts .opt.sel'))    { toast('Selecione sua situação 💼'); return; }

  if (obStep < 7) { obStep++; renderStep(); }
  else { coletarOnboarding(); rodarGeracao(); }
}

function obBack() {
  if (obStep > 1) { obStep--; renderStep(); }
  else mostrar('pgPlan');
}

function sel(el, gid) {
  document.querySelectorAll('#'+gid+' .opt').forEach(o => {
    o.classList.remove('sel');
    const c = o.querySelector('.optCk'); if(c) c.textContent='';
  });
  el.classList.add('sel');
  const c = el.querySelector('.optCk'); if(c) c.textContent='✓';
}

function showR(show, lbl) {
  const w = document.getElementById('rendaW');
  w.style.display = show ? 'flex' : 'none';
  if (lbl) document.getElementById('rendaLbl').textContent = lbl;
}

function coletarOnboarding() {
  U.nome    = (document.getElementById('ob_nome').value||'').trim() || U.nome || 'Usuário';
  const dia = document.getElementById('ob_dia').value;
  const mes = document.getElementById('ob_mes').value;
  const ano = document.getElementById('ob_ano').value;
  U.nasc    = `${ano}-${String(mes).padStart(2,'0')}-${String(dia).padStart(2,'0')}`;
  const ageMs = new Date() - new Date(U.nasc);
  U.idade   = Math.floor(ageMs/(365.25*24*3600*1000));
  if (isNaN(U.idade)||U.idade<5||U.idade>120) U.idade=25;
  U.sexo    = document.getElementById('ob_sexo').value || 'Não informado';
  U.altura  = document.getElementById('ob_alt').value || '170';
  U.peso    = document.getElementById('pesoSli').value;
  U.metaPeso= document.getElementById('metaSli').value;
  const gEl = document.querySelector('#gOpts .opt.sel');
  U.objetivo= gEl ? gEl.querySelector('.optN').textContent : 'Ganhar massa';
  const lEl = document.querySelector('#lvlOpts .opt.sel');
  U.nivel   = lEl ? lEl.querySelector('.optN').textContent : 'Intermediário';
  const loEl= document.querySelector('#localOpts .opt.sel');
  U.local   = loEl ? loEl.querySelector('.optN').textContent : 'Academia';
  const frEl= document.querySelector('#frOpts .opt.sel');
  U.freq    = frEl ? frEl.querySelector('.optN').textContent : '3–4 dias/semana';
  const dEl = document.querySelector('#dietOpts .opt.sel');
  U.dieta   = dEl ? dEl.querySelector('.optN').textContent : 'Sem restrições';
  U.ngosta  = (document.getElementById('ob_ngosta').value||'').trim() || 'nada';
  const emEl= document.querySelector('#empOpts .opt.sel');
  U.emprego = emEl ? emEl.querySelector('.optN').textContent : 'Não informado';
  U.renda   = document.getElementById('ob_renda').value;
  U.onboarded = true;
  DB.set('u:'+U.email, U);
  DB.set('session', U.email);
}

