function showWD(diaName){
  const plan=DB.get('w:'+U.email); if(!plan) return;
  const d=plan.dias.find(x=>x.dia===diaName); if(!d||d.tipo==='descanso') return;
  const mid='mW'+Date.now();
  let html=`<div class="mdlH"></div><div class="mdlT">${d.nome} 💪</div>
    <div style="display:flex;gap:8px;margin-bottom:14px">
      <span class="tag tg">${d.dia}</span><span class="tag ts">${d.duracao} min</span></div>
    <div style="display:flex;flex-direction:column;gap:9px">`;
  d.exer.forEach(ex=>{
    const ytQ = encodeURIComponent(ex.nome + ' exercício como fazer');
    const ytUrl = 'https://www.youtube.com/results?search_query=' + ytQ;
    html+=`<div class="card" style="background:var(--sur2);padding:12px">
      <div style="display:flex;align-items:center;justify-content:space-between">
        <div style="font-size:13px;font-weight:700">${ex.nome}</div>
        <a href="${ytUrl}" target="_blank" style="display:inline-flex;align-items:center;gap:4px;background:#ff0000;color:#fff;border-radius:6px;padding:4px 9px;font-size:10px;font-weight:700;text-decoration:none;letter-spacing:.5px;font-family:'Share Tech Mono',monospace">▶ VER</a>
      </div>
      <div style="font-size:11px;color:var(--dim);margin-top:5px">${ex.series} séries · ${ex.reps} reps · ${ex.descanso||'60s'} descanso</div></div>`;
  });
  html+=`</div><button class="btnG" style="margin-top:14px" onclick="markWDone('${d.nome}','${mid}')">✓ Marcar como feito</button>`;
  const mov=document.createElement('div'); mov.className='mov on'; mov.id=mid;
  mov.innerHTML=`<div class="mdl">${html}</div>`;
  mov.onclick=ev=>{if(ev.target===mov)mov.remove();};
  document.body.appendChild(mov);
}

function markWDone(nome,mid){
  const wks=DB.get('k:'+U.email)||[];
  if(!wks.some(x=>x.date===hoje()&&x.grupo===nome))
    DB.push('k:'+U.email,{id:Date.now(),grupo:nome,dur:60,ser:20,date:hoje()});
