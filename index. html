// ═══════════════════════════════════════════════════════════════
function renderHome() {
  const meals = DB.get('m:'+U.email)||[];
  const txs   = DB.get('t:'+U.email)||[];
  const wks   = DB.get('k:'+U.email)||[];
  const goals = DB.get('g:'+U.email)||[];
  const tod   = hoje();

  const todM  = meals.filter(m=>m.date===tod);
  const totK  = todM.reduce((s,m)=>s+(+m.kcal||0),0);
  const totIn = txs.filter(t=>t.type==='receita').reduce((s,t)=>s+(+t.val||0),0);
  const totOut= txs.filter(t=>t.type==='despesa').reduce((s,t)=>s+(+t.val||0),0);
  const saldo = totIn-totOut;
  const weekW = wks.filter(w=>w.date>=segunda()).length;
  const todW  = wks.some(w=>w.date===tod);

  document.getElementById('hKcal').textContent   = totK>0?totK:'—';
  document.getElementById('hTreino').textContent = weekW>0?weekW+'x':'—';
  document.getElementById('hSaldo').textContent  = (totIn+totOut)>0?'R$'+Math.abs(saldo).toFixed(0):'—';
  document.getElementById('hMetas').textContent  = goals.length>0?goals.filter(g=>!g.done).length+'/'+goals.length:'—';
  document.getElementById('heroSub').textContent = weekW>0?`${weekW} treino(s) essa semana 💪`:'Comece registrando seu primeiro dia!';

  let prog=0;
  if(totK>0) prog+=33;
  if(todW)   prog+=33;
  if(txs.length>0) prog+=34;
  document.getElementById('homeProg').style.width = prog+'%';
  document.getElementById('homePct').textContent  = prog+'%';

  // Streak
  const dLbls=['D','S','T','Q','Q','S','S'];
  const now=new Date(); let sh='<div class="strR">';
  for(let i=6;i>=0;i--){
    const d=new Date(now); d.setDate(now.getDate()-i);
    const ds=dStr(d);
    const ativo=wks.some(w=>w.date===ds)||meals.some(m=>m.date===ds);
    const isHoje=ds===tod;
    sh+=`<div class="sd ${isHoje?'sdT':ativo?'sdY':'sdN'}">${dLbls[d.getDay()]}</div>`;
  }
  let streak=0; const dd=new Date();
  for(let i=0;i<365;i++){const ds=dStr(dd);if(wks.some(w=>w.date===ds)||meals.some(m=>m.date===ds)){streak++;dd.setDate(dd.getDate()-1);}else break;}
  sh+=`</div><div style="font-size:11px;color:var(--dim);margin-top:8px">${streak>0?`🔥 ${streak} dia${streak>1?'s':''} seguido${streak>1?'s':''}`:'Comece hoje!'}</div>`;
  document.getElementById('streakArea').innerHTML=sh;

  // Treino de hoje
  const hwEl=document.getElementById('homeWorkout');
  const wplan=DB.get('w:'+U.email);
  const dow=new Date().toLocaleDateString('pt-BR',{weekday:'long'});
  const pd=wplan?wplan.dias.find(d=>dow.toLowerCase().slice(0,3)===d.dia.toLowerCase().slice(0,3)):null;
  if(pd){
    const done=wks.some(w=>w.date===tod);
    const isRest=pd.tipo==='descanso';
    hwEl.innerHTML=`<div class="wd"><div class="wdn ${done?'wdnY':isRest?'wdnR':'wdnT'}">${pd.nome[0]}</div>
      <div style="flex:1"><div style="font-size:13px;font-weight:600">${pd.nome}</div>
        <div style="font-size:11px;color:var(--dim);margin-top:2px">${pd.duracao} min${!isRest?' · '+(pd.exer?.length||0)+' exercícios':''}</div>
      </div><span class="tag ${done?'tl':isRest?'ts':'tg'}">${done?'✓ FEITO':isRest?'😴':'▶ HOJE'}</span></div>`;
  } else {
    hwEl.innerHTML=`<div class="empty"><div class="ei">💪</div><div class="et">Nenhum treino ainda</div></div>`;
  }

  // Finanças
  const hfEl=document.getElementById('homeFinance');
  if(!txs.length){hfEl.innerHTML=`<div class="empty"><div class="ei">💰</div><div class="et">Nenhuma transação</div></div>`;return;}
  const ic={alimentação:'🛒',saúde:'🏋️',moradia:'🏠',lazer:'🎭',transporte:'🚗',investimento:'📈',outros:'💸'};
  hfEl.innerHTML=`<div class="card" style="padding:4px 12px">${txs.slice(-3).reverse().map(t=>
    `<div class="tx"><div class="txIco" style="background:rgba(${t.type==='receita'?'61,255,200':'255,87,87'},.12)">${ic[t.cat]||'💸'}</div>
      <div class="txB"><div class="txN">${t.desc}</div><div class="txC">${t.cat}</div></div>
      <div class="txA ${t.type==='receita'?'txIn':'txOut'}">${t.type==='receita'?'+':'-'}R$${(+t.val).toFixed(0)}</div>
    </div>`).join('')}</div>`;
}

