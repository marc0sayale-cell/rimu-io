let _fbApp=null, _auth=null, _db=null, _fbLoaded=false;
function _loadFirebase(cb) {
  if (_fbLoaded) { if(cb) cb(); return; }
  const urls = [
    'https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js',
    'https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js',
    'https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js'
  ];
  let i = 0;
  function next() {
    if (i >= urls.length) {
      try {
        if (!_fbApp) {
          _fbApp = firebase.initializeApp(firebaseConfig);
          _auth  = firebase.auth();
          _db    = firebase.firestore();
        }
        _fbLoaded = true;
      } catch(e) { console.warn('Firebase init falhou:', e); }
      if (cb) cb(); return;
    }
    const s = document.createElement('script');
    s.src = urls[i++];
    s.onload = next;
    s.onerror = () => { if(cb) cb(); };
    document.head.appendChild(s);
  }
  next();
}
const DB = {
  get(k)       { try { const r=localStorage.getItem('evo_'+k); return r===null?null:JSON.parse(r); } catch(e){return null;} },
  set(k,v)     {
    try {
      localStorage.setItem('evo_'+k, JSON.stringify(v));
      if (_db && _auth && _auth.currentUser) {
        _db.collection('users').doc(_auth.currentUser.uid)
          .set({[k.replace(/:/g,'__')]: JSON.stringify(v)},{merge:true}).catch(()=>{});
      }
      return true;
    } catch(e){return false;}
  },
  del(k)       { try { localStorage.removeItem('evo_'+k); } catch(e){} },
  push(k,item) { const a=this.get(k)||[]; a.push(item); this.set(k,a); },
  async syncFromCloud(uid) {
    if (!_db) return false;
    try {
      const doc = await _db.collection('users').doc(uid).get();
      if (doc.exists && doc.data()) {
        const cloudData = doc.data();
        // MERGE: cloud prevalece, mas mantém dados locais que não estão no cloud
        Object.entries(cloudData).forEach(([k,v]) => {
          const lk = 'evo_' + k.replace(/__/g,':');
          // Só sobrescreve se cloud tem dados
          if (v !== null && v !== undefined && v !== '') {
            localStorage.setItem(lk, v);
          }
        });
        // Após sync, salvar dados locais de volta ao cloud (garante que cloud tem tudo)
        const allLocal = {};
        for (let i = 0; i < localStorage.length; i++) {
          const key = localStorage.key(i);
          if (key && key.startsWith('evo_')) {
            const ck = key.replace('evo_','').replace(/:/g,'__');
            allLocal[ck] = localStorage.getItem(key);
          }
        }
        if (Object.keys(allLocal).length > 0) {
          _db.collection('users').doc(uid).set(allLocal, {merge:true}).catch(()=>{});
        }
        return true;
      } else {
        // Cloud vazio: salvar dados locais para cloud (primeira vez no PC)
        const allLocal = {};
        for (let i = 0; i < localStorage.length; i++) {
          const key = localStorage.key(i);
          if (key && key.startsWith('evo_')) {
            const ck = key.replace('evo_','').replace(/:/g,'__');
            allLocal[ck] = localStorage.getItem(key);
          }
        }
        if (Object.keys(allLocal).length > 0) {
          _db.collection('users').doc(uid).set(allLocal, {merge:true}).catch(()=>{});
        }
      }
    } catch(e) { console.warn('Sync error:', e); }
    return false;
  }
};

