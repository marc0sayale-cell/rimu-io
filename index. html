// ═══════════════════════════════════════════════════════════════
//  NOTIFICATION HELPER — robusto para Android/iOS/PWA
// ═══════════════════════════════════════════════════════════════
const Notif = {
  // Verifica suporte REAL sem polyfill que interfere
  get supported() {
    if (!('Notification' in window)) return false;
    // iOS Safari só funciona instalado como PWA
    if (/iphone|ipad|ipod/i.test(navigator.userAgent)) {
      return window.navigator.standalone === true ||
             window.matchMedia('(display-mode:standalone)').matches;
    }
    return true;
  },
  get permission() {
    if (!this.supported) return 'denied';
    return Notification.permission;
  },
  async request() {
    if (!this.supported) return 'denied';
    try {
      // Alguns browsers antigos retornam void em vez de Promise
      const result = Notification.requestPermission();
      if (result && typeof result.then === 'function') return await result;
      return Notification.permission;
    } catch(e) { return 'denied'; }
  },
  send(title, body, opts={}) {
    if (!this.supported) return;
    if (Notification.permission !== 'granted') return;
    try {
      new Notification(title, {
        body: body || '',
        icon: opts.icon || LOGO.mini,
        tag: opts.tag || ('evo-' + Date.now()),
        vibrate: [200, 100, 200],
      });
    } catch(e) { /* silencioso */ }
  }
};

