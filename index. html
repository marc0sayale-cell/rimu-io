function aceitarNotifBanner() {
  fecharNotifBanner();
  pedirPermissao();
}

function fecharNotifBanner() {
  const b = document.getElementById('notifBanner');
  if (b) b.remove();
}

function testNotif() {
  if (!Notif.supported) {
    toast('Notificações não suportadas neste navegador', 'err');
    return;
  }
  if (Notif.permission === 'denied') {
    toast('Bloqueado! Ative nas config do Chrome 🔕', 'err');
    return;
  }
  if (Notif.permission !== 'granted') {
    pedirPermissao();
    return;
  }
  // Tenta enviar — testa os dois métodos
  let enviou = false;

  // Método 1: via SW registration (melhor para PWA)
  const reg = window._swReg;
  if (reg && reg.showNotification) {
    reg.showNotification('🔔 Evoluai', {
      body: 'Notificações funcionando! ✓',
      icon: LOGO.icon,
      tag: 'evo-test',
      vibrate: [200, 100, 200],
    }).then(() => {
      toast('Notificação enviada via SW ✓', 'ok');
    }).catch(() => {
      // Método 2: Notification API direta
      Notif.send('🔔 Evoluai', 'Notificações funcionando! ✓');
      toast('Notificação enviada ✓', 'ok');
    });
    return;
  }

  // Método 2 direto
  Notif.send('🔔 Evoluai', 'Notificações funcionando! ✓');
  toast('Notificação enviada ✓', 'ok');
}

window.addEventListener('load',()=>{ initPWA(); checkiOS(); });

