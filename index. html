//  MIGRAÇÃO DE KEYS — rimu_ → evo_ (versão antiga → nova)
// ═══════════════════════════════════════════════════════════════
function migrarKeysAntigas() {
  if (localStorage.getItem('_evo_migrated')) return; // já migrou
  let migrou = 0;
  for (let i = localStorage.length - 1; i >= 0; i--) {
    const key = localStorage.key(i);
    if (!key) continue;
    if (key.startsWith('rimu_')) {
      const novaKey = 'evo_' + key.slice(5);
      // Só copia se a nova key não existir ainda
      if (!localStorage.getItem(novaKey)) {
        localStorage.setItem(novaKey, localStorage.getItem(key));
        migrou++;
      }
    }
  }
  localStorage.setItem('_evo_migrated', '1');
  if (migrou > 0) console.log('[Evoluai] Migradas', migrou, 'keys do localStorage');
}

