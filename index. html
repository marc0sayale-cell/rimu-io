function iniciarApp() {
  DB.set('session', U.email);
  DB.set('u:'+U.email, U);
  mostrar('pgApp');
  const dd=['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const mm=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  const n=new Date();
  document.getElementById('heroDate').textContent=`${dd[n.getDay()]}, ${n.getDate()} ${mm[n.getMonth()]} ${n.getFullYear()}`;
  atualizarPerfil();
  renderHome();
  renderDieta();
  renderTreino();
  renderFinancas();
  renderMetas();

  // Notificações: inicia se já tem permissão, senão pede após 3s (primeira vez)
  if (Notif.permission === 'granted') {
    iniciarNotificacoes();
  } else if (Notif.permission !== 'denied' && !DB.get('notif_asked')) {
    setTimeout(() => pedirPermissaoAuto(), 3000);
  }

  // ── Usuário PRO sem planos gerados? Gera em background silencioso ──
  if (U.plan === 'pro' && U.onboarded) {
    const temDieta  = !!DB.get('d:'+U.email);
    const temTreino = !!DB.get('w:'+U.email);
    if (!temDieta || !temTreino) {
      gerarPlanosBackground(temDieta, temTreino);
    }
  }
}

async function gerarPlanosBackground(temDieta, temTreino) {
  // Recarrega U do storage para ter dados mais atuais
  const salvo = DB.get('u:'+U.email) || {};
  Object.assign(U, salvo);
  // Só preenche fallback se campo REALMENTE estiver vazio
  U.peso     = U.peso     || '75';
  U.metaPeso = U.metaPeso || '70';
  U.altura   = U.altura   || '170';
  U.idade    = U.idade    || 25;
  U.sexo     = U.sexo     || 'Não informado';
  U.objetivo = U.objetivo || 'Ganhar massa muscular';
  U.nivel    = U.nivel    || 'Intermediário';
  U.local    = U.local    || 'Academia';
  U.freq     = U.freq     || '3–4 dias/semana';
  U.dieta    = U.dieta    || 'Sem restrições';
  U.ngosta   = U.ngosta   || 'nada';

  toast('⏳ Gerando seu plano personalizado...', 'ok');

  try {
    if (!temDieta) {
      const dieta = await gerarDieta();
      DB.set('d:'+U.email, dieta);
      renderDieta();
    }
    if (!temTreino) {
      const treino = await gerarTreino();
      DB.set('w:'+U.email, treino);
      renderTreino();
    }
    if (!DB.get('g:'+U.email)) {
      DB.set('g:'+U.email, gerarMetasIniciais());
      renderMetas();
    }
    renderHome();
    toast('✅ Plano gerado com sucesso!', 'ok');
  } catch(e) {
    // Usa fallback estático
    if (!temDieta)  { DB.set('d:'+U.email, fbDieta());  renderDieta(); }
    if (!temTreino) { DB.set('w:'+U.email, fbTreino()); renderTreino(); }
    renderHome();
    toast('Plano padrão carregado ✓', 'ok');
  }
}


