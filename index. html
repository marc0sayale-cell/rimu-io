    permBlock.style.display = 'none';
  } else if (perm === 'denied') {
    // Bloqueado pelo usuário — mostrar instruções para ativar
    permBlock.style.display = 'block';
    permBlock.innerHTML = `
      <div style="font-size:22px;margin-bottom:6px">🔕</div>
      <div style="font-size:13px;font-weight:700;margin-bottom:4px">Notificações bloqueadas</div>
      <div style="font-size:11px;color:var(--dim);margin-bottom:10px;line-height:1.6">
        Ative nas <strong>configurações do Chrome</strong>:<br>
        Menu ⋮ → Configurações → Notificações → Evoluai → Permitir
      </div>`;
  } else {
    // 'default' — nunca pediu permissão
    permBlock.style.display = 'block';
  }

  // Carregar configurações salvas
  const cfg = DB.get('notif:'+U.email) || {};
  document.getElementById('nt_agua').checked      = cfg.agua      ?? false;
  document.getElementById('nt_agua_int').value    = cfg.agua_int  ?? '2';
  document.getElementById('nt_treino').checked    = cfg.treino    ?? false;
  document.getElementById('nt_treino_hr').value   = cfg.treino_hr ?? '07:00';
  document.getElementById('nt_refeicao').checked  = cfg.refeicao  ?? false;
  document.getElementById('nt_peso').checked      = cfg.peso      ?? false;
  document.getElementById('nt_peso_hr').value     = cfg.peso_hr   ?? '08:00';
  document.getElementById('nt_fin').checked       = cfg.fin       ?? false;
  document.getElementById('nt_metas').checked     = cfg.metas     ?? false;
  openMov('mNotif');
}

async function pedirPermissao() {
  const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isStandalone = window.navigator.standalone || window.matchMedia('(display-mode:standalone)').matches;
  if (isIOS && !isStandalone) {
    toast('No iPhone instale o app primeiro', 'err');
    const blk = document.getElementById('notifPermBlock');
    if (blk) {
      blk.style.display = 'block';
      blk.innerHTML = '<div style="font-size:20px;margin-bottom:6px">📲</div>'
        + '<div style="font-size:13px;font-weight:700;margin-bottom:6px">Instale o app primeiro</div>'
        + '<div style="font-size:11px;color:var(--dim);line-height:1.7">'
        + 'Toque em <strong>Compartilhar</strong> no Safari<br>'
        + '→ <strong>Adicionar à Tela de Início</strong></div>';
    }
    return;
  }
  if (!('Notification' in window)) { toast('Navegador não suporta notificações', 'err'); return; }
  if (Notification.permission === 'granted') { iniciarNotificacoes(); toast('Notificações já ativadas ✓', 'ok'); return; }
  if (Notification.permission === 'denied') { toast('Bloqueado! Vá em config do Chrome → Permitir', 'err'); return; }
  try {
    const perm = await Notification.requestPermission();
    const blk = document.getElementById('notifPermBlock');
    if (perm === 'granted') {
      if (blk) blk.style.display = 'none';
      toast('Notificações ativadas! 🔔', 'ok');
      if ('serviceWorker' in navigator) navigator.serviceWorker.ready.then(r => { window._swReg = r; }).catch(()=>{});
      iniciarNotificacoes();
      setTimeout(() => { Notif.send('🔔 Evoluai ativado!', 'Você receberá lembretes de treino e água.'); }, 500);
    } else {
      if (blk) {
        blk.style.display = 'block';
        blk.innerHTML = '<div style="font-size:13px;font-weight:700;">🔕 Permissão negada</div>'
          + '<div style="font-size:11px;color:var(--dim);margin-top:6px;">Chrome → Menu ⋮ → Configurações → Notificações → Permitir</div>';
      }
      toast('Permissão negada 🔕', 'err');
    }
  } catch(e) { toast('Erro ao pedir permissão', 'err'); }
}

function saveNotifSettings() {
  const cfg = {
    agua:      document.getElementById('nt_agua').checked,
    agua_int:  document.getElementById('nt_agua_int').value,
    treino:    document.getElementById('nt_treino').checked,
    treino_hr: document.getElementById('nt_treino_hr').value,
    refeicao:  document.getElementById('nt_refeicao').checked,
    peso:      document.getElementById('nt_peso').checked,
    peso_hr:   document.getElementById('nt_peso_hr').value,
    fin:       document.getElementById('nt_fin').checked,
    metas:     document.getElementById('nt_metas').checked,
  };
  DB.set('notif:'+U.email, cfg);
  iniciarNotificacoes();
}

function enviarNotif(titulo, corpo, icone) {
  // Tenta via Service Worker primeiro (funciona em PWA instalado/background)
  const reg = window._swReg || (navigator.serviceWorker && navigator.serviceWorker.controller);
  if (reg && reg.showNotification) {
    reg.showNotification(titulo, {
      body: corpo,
      icon: icone || './icon-192.png',
      badge: LOGO.mini,
      tag: 'evo-' + Date.now(),
      vibrate: [200, 100, 200],
    }).catch(() => Notif.send(titulo, corpo, { icon: icone }));
    return;
  }
  // Fallback: Notification API direta (funciona em foreground)
  Notif.send(titulo, corpo, { icon: icone });
}

// Agenda notificação via SW (funciona mesmo com app minimizado)
function agendarNotifSW(titulo, corpo, delayMs, tag) {
  const ctrl = navigator.serviceWorker && navigator.serviceWorker.controller;
  if (ctrl) {
    ctrl.postMessage({ type: 'SCHEDULE_NOTIF', title: titulo, body: corpo, delayMs, tag });
    return true;
  }
  return false;
}

function iniciarNotificacoes() {
  // Limpar timers antigos
  _notifTimers.forEach(t => clearInterval(t));
  _notifTimers = [];

  if (Notif.permission !== 'granted') return;
  const cfg = DB.get('notif:'+U.email) || {};

  // 💧 ÁGUA — intervalo em horas
  if (cfg.agua) {
    const ms = (parseInt(cfg.agua_int) || 2) * 60 * 60 * 1000;
    const t = setInterval(() => {
      const msgs = [
        'Beba um copo de água agora! 💧',
        'Hora de se hidratar! Seu corpo agradece 💧',
        'Você bebeu água nos últimos tempos? 💧',
        'Hidratação é fundamental para a performance! 💧'
      ];
      enviarNotif('💧 Evoluai — Hidratação', msgs[Math.floor(Math.random()*msgs.length)]);
    }, ms);
    _notifTimers.push(t);
  }

  // ⏰ Verificador de horários (checa a cada minuto)
  const horarioTimer = setInterval(() => {
    const agora = new Date();
    const hhmm = agora.getHours().toString().padStart(2,'0') + ':' + agora.getMinutes().toString().padStart(2,'0');
    const diaSemana = agora.getDay(); // 0=Dom

    // 💪 TREINO
    if (cfg.treino && cfg.treino_hr === hhmm) {
      const msgs = ['Hora de treinar! Bora lá! 💪', 'Não pule o treino hoje! 💪', 'Seu treino de hoje te espera! 💪'];
      enviarNotif('💪 Hora do Treino!', msgs[Math.floor(Math.random()*msgs.length)]);
    }

    // 🍽️ REFEIÇÕES
    if (cfg.refeicao) {
      if (hhmm === '08:00') enviarNotif('🍽️ Café da manhã', 'Registrou seu café da manhã hoje? 🌅');
      if (hhmm === '12:30') enviarNotif('🍽️ Hora do almoço', 'Não se esqueça de registrar o almoço! 🥗');
      if (hhmm === '19:00') enviarNotif('🍽️ Hora do jantar', 'Registre seu jantar para manter o controle! 🌙');
    }

    // ⚖️ PESO
    if (cfg.peso && cfg.peso_hr === hhmm) {
      const meta = U.metaPeso || '';
      enviarNotif('⚖️ Registre seu peso', `Pesou hoje? Sua meta é ${meta}kg. Continue firme!`);
    }

    // 💰 FINANÇAS — domingo às 20:00
    if (cfg.fin && diaSemana === 0 && hhmm === '20:00') {
      const txs = DB.get('t:'+U.email) || [];
      const semana = txs.filter(t => {
        const d = new Date(t.date + 'T12:00:00');
        const diff = (agora - d) / (1000*60*60*24);
        return diff <= 7;
      });
      const gastos = semana.filter(t=>t.type==='despesa').reduce((s,t)=>s+(+t.val||0),0);
      enviarNotif('💰 Resumo Financeiro', `Você gastou R$${gastos.toFixed(2)} essa semana. Confira suas finanças!`);
    }

    // 🎯 METAS — domingo às 20:30
    if (cfg.metas && diaSemana === 0 && hhmm === '20:30') {
      const metas = DB.get('m:'+U.email) || [];
      const ativas = metas.filter(m => !m.done).length;
      enviarNotif('🎯 Progresso das Metas', `Você tem ${ativas} meta${ativas !== 1 ? 's' : ''} em andamento. Como está seu progresso?`);
    }

  }, 60000); // checa todo minuto
  _notifTimers.push(horarioTimer);
}

// Pedido automático na primeira abertura — banner bonito
