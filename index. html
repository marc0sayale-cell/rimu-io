    prot:+(document.getElementById('mealProt').value)||0,
    carbo:+(document.getElementById('mealCarbo').value)||0,
    gord:+(document.getElementById('mealGord').value)||0,
    tipo:document.getElementById('mealTipo').value,date:hoje()});
