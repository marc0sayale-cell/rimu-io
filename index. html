async function rodarGeracao() {
  mostrar('pgGen');
  if (U.plan === 'free') { await sleep(1200); iniciarApp(); return; }

  markGen(0,'Analisando perfil e objetivos...');
  await sleep(900); doneGen(0);

  markGen(1,'Gerando plano alimentar semanal...');
  const dieta = await gerarDieta();
  DB.set('d:'+U.email, dieta); doneGen(1); await sleep(300);

  markGen(2,'Criando plano de treinos...');
  const treino = await gerarTreino();
  DB.set('w:'+U.email, treino); doneGen(2); await sleep(300);

  markGen(3,'Configurando metas iniciais...');
  await sleep(600);
  DB.set('g:'+U.email, gerarMetasIniciais()); doneGen(3);
  await sleep(500);
  iniciarApp();
