<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<title>Evoluai</title>
<meta name="description" content="Sua rotina personalizada por IA. Dieta semanal, plano de treinos, controle financeiro e metas — tudo em um app.">
<meta property="og:title" content="Evoluai">
<meta property="og:description" content="Sua rotina personalizada por IA">
<meta property="og:type" content="website">
<link rel='preconnect' href='https://fonts.googleapis.com'>
<link rel='preconnect' href='https://fonts.gstatic.com' crossorigin>
<link rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Alfa+Slab+One&family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap'>
<style>
/* Fonts loaded via <link> tag above */
:root{
  /* ── EVOLUAI PALETTE — Roxo Espacial ── */
  /* #100319 Roxo Espacial — fundo base */
  --bg:#100319;--bg2:#160422;--sur:#3F2768;--sur2:rgba(16,3,25,0.97);
  /* Bordas com amestista */
  --bd:rgba(103,58,183,0.35);--bd2:rgba(103,58,183,0.65);
  /* #673AB7 Roxo Elétrico — principal */
  --pur:#673AB7;--pur2:#5e35b1;--pur3:#4527a0;
  /* #3F2768 Roxo Amestista — cards/menus */
  --sur-card:#3F2768;
  /* Magenta — conquistas, alertas, metas */
  --yel:#e040fb;--yel2:#ce39e0;--pink:#e040fb;--hp:#e040fb;--coral:#e040fb;
  /* Aliases */
  --ice:#9c6fe4;--cyan:#9c6fe4;--sky:#9c6fe4;--mp:#e040fb;
  --lime:#e040fb;--mint:#9c6fe4;--green:#b39ddb;
  --gold:#e040fb;--fire:#f06292;--xp:#e040fb;--blue:#673AB7;
  --txt:#ede7f6;--dim:#9e8bc2;--dead:#2a1545;
  --r:14px;--rs:10px;
  --gp:0 0 28px rgba(103,58,183,.6);
  --gy:0 0 28px rgba(224,64,251,.55);
  --gc:0 0 28px rgba(103,58,183,.5);
  --glass:rgba(63,39,104,0.35);--glass2:rgba(63,39,104,0.55);
  --white:var(--txt);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;width:100%;overflow:hidden;background:#100319;font-family:'Rajdhani',sans-serif;color:var(--txt);letter-spacing:.3px;}
input,select,button,textarea{font-family:'Rajdhani',sans-serif;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:2px;}
.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0;}
@media(hover:none){::-webkit-scrollbar{display:none;}}
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:99998;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.015) 3px,rgba(0,0,0,.015) 4px);}
.pg{position:fixed;inset:0;display:none;flex-direction:column;background:#100319;z-index:10;}
.pg.on{display:flex;}

/* SPLASH */
#pgSp{align-items:center;justify-content:center;
  background:radial-gradient(ellipse 70% 60% at 40% 50%,rgba(180,0,255,.18) 0%,transparent 65%),radial-gradient(ellipse 50% 45% at 85% 25%,rgba(180,0,255,.1) 0%,transparent 60%),#000;}
.sp-grid{position:absolute;inset:0;pointer-events:none;
  background-image:linear-gradient(rgba(103,58,183,.15) 1px,transparent 1px),linear-gradient(90deg,rgba(103,58,183,.15) 1px,transparent 1px);
  background-size:44px 44px;animation:gridDrift 20s linear infinite;}
@keyframes gridDrift{to{background-position:44px 44px;}}
.sp-vignette{position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 90% 90% at 50% 50%,transparent 50%,rgba(8,7,13,.7) 100%);}
.sp-frame{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px;padding:44px 64px;border:1px solid rgba(67,97,238,.35);background:rgba(6,16,31,.7);box-shadow:0 0 60px rgba(67,97,238,.15),inset 0 0 40px rgba(0,0,0,.5);}
.sp-frame::before,.sp-frame::after{content:'';position:absolute;width:18px;height:18px;border-color:var(--yel);border-style:solid;}
.sp-frame::before{top:-2px;left:-2px;border-width:2px 0 0 2px;}
.sp-frame::after{bottom:-2px;right:-2px;border-width:0 2px 2px 0;}
.sp-tag{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:5px;color:var(--cyan);text-transform:uppercase;opacity:0;animation:fadeUp .4s .15s forwards;}
.sp-l{font-family:'Alfa Slab One',serif;font-size:80px;font-weight:400;font-style:normal;letter-spacing:8px;line-height:1;
  background:linear-gradient(135deg,var(--pur) 0%,var(--pink) 60%,var(--pur2) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 30px rgba(180,0,255,.8)) drop-shadow(0 0 60px rgba(180,0,255,.4));
  opacity:0;transform:scale(.88) translateY(8px);animation:popIn .8s cubic-bezier(.22,1,.36,1) .35s forwards;}
.sp-dot{width:6px;height:6px;background:var(--pink);margin:0 auto;opacity:0;animation:fadeUp .3s .9s forwards;box-shadow:var(--gp);}
.sp-s{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:6px;color:var(--dim);opacity:0;animation:fadeUp .4s 1s forwards;}
.sp-bar{width:140px;height:3px;background:var(--dead);margin-top:24px;overflow:hidden;opacity:0;animation:fadeUp .3s 1.1s forwards;}
.sp-fill{height:100%;background:linear-gradient(90deg,var(--pur),var(--yel));width:0;animation:fillBar 1.5s 1.2s cubic-bezier(.4,0,.2,1) forwards;}
.sp-pct{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--yel);margin-top:6px;opacity:0;animation:fadeUp .3s 1.2s forwards;letter-spacing:2px;}
@keyframes popIn{to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}
@keyframes fillBar{to{width:100%}}

/* AUTH */
#pgAuth{overflow-y:auto;background:radial-gradient(ellipse 100% 50% at 50% -5%,rgba(180,0,255,.15) 0%,transparent 55%),radial-gradient(ellipse 60% 40% at 90% 90%,rgba(180,0,255,.07) 0%,transparent 60%),#000;}
.auth-grid{position:fixed;inset:0;pointer-events:none;z-index:0;background-image:linear-gradient(rgba(103,58,183,.1) 1px,transparent 1px),linear-gradient(90deg,rgba(103,58,183,.1) 1px,transparent 1px);background-size:48px 48px;}
.auth-glow{display:none;}
.auth-hero{display:flex;flex-direction:column;align-items:center;padding:56px 24px 18px;text-align:center;position:relative;z-index:1;}
.auth-logo{font-family:'Alfa Slab One',serif;font-size:64px;font-weight:400;font-style:normal;letter-spacing:6px;line-height:1;background:linear-gradient(135deg,var(--pur) 0%,var(--yel) 70%,var(--pur3) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 24px rgba(180,0,255,.7)) drop-shadow(0 0 48px rgba(180,0,255,.3));}
.auth-sub{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--dim);margin-top:9px;letter-spacing:2px;}
.level-badge{display:inline-flex;align-items:center;gap:8px;margin-top:14px;border:1px solid rgba(67,97,238,.4);padding:7px 18px;background:rgba(67,97,238,.06);}
.lbTxt{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--cyan);letter-spacing:2px;}
.pills{display:flex;gap:7px;margin-top:12px;flex-wrap:wrap;justify-content:center;}
.pill{background:rgba(245,197,24,.05);border:1px solid rgba(245,197,24,.2);padding:4px 12px;font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--dim);letter-spacing:1px;border-radius:20px;}
.auth-sheet{background:linear-gradient(180deg,rgba(6,16,31,.97),var(--sur));border-top:2px solid var(--pur);padding:24px 22px 48px;position:relative;z-index:1;}
.auth-sheet::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--blue),var(--pink),transparent);opacity:.4;}
.tabs{display:flex;gap:0;background:var(--bg2);border:1px solid var(--bd);margin-bottom:20px;border-radius:var(--rs);}
.tabBtn{flex:1;padding:11px;border:none;background:transparent;color:var(--dim);font-size:12px;font-weight:700;cursor:pointer;transition:all .25s;font-family:'Share Tech Mono',monospace;letter-spacing:2px;text-transform:uppercase;border-radius:var(--rs);}
.tabBtn.on{background:linear-gradient(135deg,var(--pur),var(--pink));color:#fff;box-shadow:0 0 16px rgba(180,0,255,.4);}
.af{display:flex;flex-direction:column;gap:12px;}
.af.hide{display:none;}
.fl{font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--dim);margin-bottom:4px;}
.fi{background:rgba(22,4,34,.9);border:1px solid rgba(103,58,183,.4);border-radius:var(--rs);padding:12px 14px;color:var(--txt);font-size:15px;outline:none;transition:all .2s;width:100%;-webkit-appearance:none;font-family:'Rajdhani',sans-serif;}
.fi:focus{border-color:#673AB7;box-shadow:0 0 0 2px rgba(103,58,183,.3),0 0 14px rgba(103,58,183,.2);}
.fi::placeholder{color:var(--dead);}
.fi option{background:var(--sur);}
.btnG{background:linear-gradient(135deg,#673AB7,#4527a0);color:#fff;border:none;border-radius:var(--rs);padding:15px;font-size:14px;font-weight:700;cursor:pointer;width:100%;transition:all .2s;font-family:'Rajdhani',sans-serif;letter-spacing:3px;text-transform:uppercase;box-shadow:0 4px 20px rgba(103,58,183,.5);touch-action:manipulation;-webkit-user-select:none;user-select:none;}
.btnG:active{transform:scale(.98);}
.divx{display:flex;align-items:center;gap:10px;color:var(--dim);font-size:11px;font-family:'Share Tech Mono',monospace;letter-spacing:1px;}
.divx::before,.divx::after{content:'';flex:1;height:1px;background:var(--bd);}
.srow{display:flex;gap:10px;}
.sbtn{flex:1;padding:11px;border:1px solid var(--bd);background:rgba(255,255,255,.02);border-radius:var(--rs);color:var(--txt);font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;font-family:'Rajdhani',sans-serif;}
.alink{text-align:center;font-size:13px;color:var(--dim);font-family:'Share Tech Mono',monospace;}
.alink span{color:var(--cyan);cursor:pointer;font-weight:700;}

/* PLAN */
#pgPlan{overflow-y:auto;background:var(--bg);}
.plan-inner{padding:52px 18px 48px;display:flex;flex-direction:column;gap:16px;max-width:420px;margin:0 auto;width:100%;}
.planTtl{font-family:'Alfa Slab One',serif;font-size:26px;font-weight:900;letter-spacing:2px;text-align:center;line-height:1.25;}
.planTtl span{background:linear-gradient(135deg,var(--blue),var(--cyan),var(--pink));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.planSub{text-align:center;color:var(--dim);font-size:11px;margin-top:-8px;font-family:'Share Tech Mono',monospace;letter-spacing:1px;}
.pc{padding:22px;border:1px solid var(--bd2);position:relative;overflow:hidden;border-radius:var(--r);background:var(--sur);}
.pc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.pc-pro::before{background:linear-gradient(90deg,var(--pur),var(--cyan),var(--pink));}
.pc-pro{background:linear-gradient(135deg,#0d0020,#150030);box-shadow:0 8px 40px rgba(180,0,255,.2),0 0 1px rgba(180,0,255,.5);}
.pc-free::before{background:var(--bd);}
.pcBadge{position:absolute;top:14px;right:14px;background:linear-gradient(135deg,var(--pink),var(--blue));color:#fff;font-size:9px;font-weight:900;letter-spacing:2px;padding:4px 10px;border-radius:20px;font-family:'Share Tech Mono',monospace;}
.pcName{font-family:'Alfa Slab One',serif;font-size:24px;font-weight:900;letter-spacing:3px;margin-bottom:4px;}
.pc-pro .pcName{background:linear-gradient(135deg,var(--blue),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.pc-free .pcName{color:var(--dim);}
.pcPrice{font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--dim);margin-bottom:14px;letter-spacing:1px;}
.pcPrice strong{color:var(--txt);font-size:16px;}
.pcFeats{display:flex;flex-direction:column;gap:9px;}
.pcFeat{display:flex;align-items:center;gap:9px;font-size:14px;font-weight:600;}
.ok{color:var(--yel);font-size:13px;flex-shrink:0;}
.no{color:var(--dead);font-size:13px;flex-shrink:0;}
.noTxt{color:var(--dim);}
.pcBtn{margin-top:18px;background:linear-gradient(135deg,var(--pur2),var(--pur3));color:var(--txt);border:none;border-radius:var(--rs);padding:14px;font-size:12px;font-weight:700;cursor:pointer;width:100%;font-family:'Share Tech Mono',monospace;letter-spacing:3px;text-transform:uppercase;box-shadow:var(--gp);transition:all .2s;}
.pcOut{background:transparent;color:var(--dim);border:1px solid var(--bd);border-radius:var(--rs);padding:13px;font-size:12px;cursor:pointer;width:100%;margin-top:18px;font-family:'Share Tech Mono',monospace;letter-spacing:2px;text-transform:uppercase;}

/* ONBOARDING */
#pgOb{overflow-y:auto;}
.obHd{padding:50px 18px 12px;display:flex;align-items:center;gap:12px;position:sticky;top:0;background:rgba(8,7,13,.95);backdrop-filter:blur(10px);z-index:10;flex-shrink:0;border-bottom:1px solid var(--bd);}
.obBack{width:36px;height:36px;background:var(--sur2);border:1px solid var(--bd);border-radius:var(--rs);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;flex-shrink:0;}
.obPw{flex:1;}
.obPr{display:flex;justify-content:space-between;font-size:9px;color:var(--dim);margin-bottom:5px;font-family:'Share Tech Mono',monospace;letter-spacing:1px;}
.obBar{height:3px;background:var(--dead);border-radius:2px;}
.obFill{height:100%;background:linear-gradient(90deg,var(--pur),var(--pink),var(--pur2));transition:width .45s cubic-bezier(.22,1,.36,1);border-radius:2px;box-shadow:0 0 12px rgba(180,0,255,.6);}
.obBody{padding:16px 18px 120px;}
.obStep{display:none;flex-direction:column;gap:14px;animation:slideR .3s cubic-bezier(.22,1,.36,1);}
.obStep.on{display:flex;}
@keyframes slideR{from{opacity:0;transform:translateX(22px)}to{opacity:1;transform:none}}
.obNum{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:4px;text-transform:uppercase;color:var(--cyan);}
.obTtl{font-family:'Alfa Slab One',serif;font-size:22px;font-weight:700;line-height:1.25;}
.obTtl em{color:var(--cyan);font-style:normal;text-shadow:0 0 10px var(--cyan);}
.obSub{font-size:14px;color:var(--dim);line-height:1.6;}
.obNx{position:fixed;bottom:22px;left:18px;right:18px;background:linear-gradient(135deg,var(--blue),var(--pur3));color:var(--txt);border:none;border-radius:var(--rs);padding:16px;font-size:12px;font-weight:700;cursor:pointer;z-index:20;box-shadow:var(--gp);font-family:'Share Tech Mono',monospace;letter-spacing:3px;text-transform:uppercase;transition:all .2s;}
.obNx:active{transform:scale(.98);}
.opts{display:flex;flex-direction:column;gap:8px;}
.opt{background:var(--sur);border:1px solid var(--bd);border-radius:var(--r);padding:14px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:12px;}
.opt.sel{border-color:var(--pur);background:rgba(180,0,255,.08);box-shadow:inset 3px 0 0 var(--pur),0 0 12px rgba(180,0,255,.15);}
.optIco{font-size:22px;flex-shrink:0;}
.optBd{flex:1;}
.optN{font-size:14px;font-weight:700;}
.optD{font-size:12px;color:var(--dim);margin-top:2px;}
.optCk{width:20px;height:20px;border-radius:50%;border:2px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:10px;transition:all .2s;flex-shrink:0;}
.opt.sel .optCk{background:linear-gradient(135deg,var(--pur),var(--pink));border-color:var(--pur);color:#000;font-weight:900;}
.dateRow{display:grid;grid-template-columns:1fr 1.2fr 1.6fr;gap:10px;}
.sliVal{font-family:'Alfa Slab One',serif;font-size:52px;font-weight:900;letter-spacing:2px;line-height:1;color:var(--cyan);display:flex;align-items:flex-end;gap:6px;}
.sliUnit{font-size:15px;color:var(--dim);margin-bottom:8px;}
input[type=range]{-webkit-appearance:none;width:100%;height:5px;background:var(--dead);border-radius:3px;outline:none;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;border-radius:50%;background:linear-gradient(135deg,var(--pur),var(--pink));cursor:pointer;border:3px solid #000;box-shadow:0 0 14px rgba(180,0,255,.7);}
.sliLbl{display:flex;justify-content:space-between;font-size:9px;color:var(--dim);font-family:'Share Tech Mono',monospace;letter-spacing:1px;}
.fg{display:flex;flex-direction:column;gap:4px;}
.r2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}

/* GENERATE */
#pgGen{align-items:center;justify-content:center;padding:32px;background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(147,51,234,.06) 0%,transparent 70%);}
.genW{text-align:center;display:flex;flex-direction:column;align-items:center;gap:14px;width:100%;max-width:320px;}
.genSpin{width:72px;height:72px;border-radius:50%;border:3px solid #1a001a;border-top-color:var(--pur);border-right-color:var(--pink);animation:spinAnim .9s linear infinite;box-shadow:0 0 20px rgba(180,0,255,.4);}
@keyframes spinAnim{to{transform:rotate(360deg)}}
.genLogo{font-family:'Alfa Slab One',serif;font-size:24px;font-weight:400;letter-spacing:4px;background:linear-gradient(135deg,var(--blue),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.genTtl{font-family:'Rajdhani',sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;}
.genCur{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--cyan);min-height:18px;letter-spacing:1px;}
.genList{display:flex;flex-direction:column;gap:6px;width:100%;margin-top:6px;}
.gi{display:flex;align-items:center;gap:10px;font-size:13px;padding:11px 14px;background:var(--sur);border:1px solid var(--bd);border-radius:var(--rs);text-align:left;}
.gi.done{border-color:rgba(67,97,238,.3);border-left:2px solid var(--cyan);}
.giIco{font-size:16px;flex-shrink:0;}
.giTxt{flex:1;color:var(--dim);transition:color .3s;font-family:'Rajdhani',sans-serif;font-weight:600;}
.giCk{color:var(--dead);font-size:14px;transition:color .3s;}
.gi.done .giTxt{color:var(--txt);}
.gi.done .giCk{color:var(--cyan);}

/* APP */
#pgApp{overflow:hidden;}
.appW{display:flex;flex-direction:column;height:100%;}
.topbar{padding:46px 16px 12px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;border-bottom:1px solid rgba(103,58,183,.5);background:linear-gradient(180deg,rgba(63,39,104,.6) 0%,rgba(16,3,25,.98) 100%);position:relative;}
.topbar::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--pur),var(--pink),var(--pur),transparent);opacity:.8;}
.tbLogo{font-family:'Alfa Slab One',serif;font-size:22px;font-weight:400;font-style:normal;letter-spacing:4px;background:linear-gradient(135deg,var(--pur),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 10px rgba(180,0,255,.6));}
.tbR{display:flex;align-items:center;gap:9px;}
.planTag{font-size:8px;font-weight:800;letter-spacing:2px;padding:3px 9px;border-radius:20px;font-family:'Share Tech Mono',monospace;}
.ptPro{background:linear-gradient(90deg,rgba(67,97,238,.2),rgba(247,37,133,.15));color:var(--cyan);border:1px solid rgba(67,97,238,.3);}
.ptFree{background:var(--dead);color:var(--dim);}
.av{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--pur),var(--pink));display:flex;align-items:center;justify-content:center;font-family:'Alfa Slab One',serif;font-size:13px;color:#000;cursor:pointer;flex-shrink:0;box-shadow:0 0 12px rgba(180,0,255,.5);}
.main{flex:1;overflow-y:auto;overflow-x:hidden;}
.scr{display:none;padding:12px 14px 84px;flex-direction:column;gap:12px;}
.scr.on{display:flex;}
.bnav{flex-shrink:0;display:flex;background:rgba(16,3,25,0.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid var(--bd);padding:10px 2px calc(22px + env(safe-area-inset-bottom,0px));position:relative;}
.bnav::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--pur),var(--pink),var(--pur),transparent);opacity:.8;}
.nv{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:7px 2px;cursor:pointer;position:relative;transition:all .2s;}
.nv .ni{font-size:19px;filter:grayscale(1) brightness(.35);transition:all .25s;}
.nv .nl{font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--dim);transition:color .2s;font-family:'Share Tech Mono',monospace;}
