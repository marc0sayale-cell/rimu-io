async function sendChat(){
  if(U.plan!=='pro'){openMov('mPay');return;}
  const inp=document.getElementById('cinp');
  const msg=(inp.value||'').trim(); if(!msg) return;
  inp.value='';
  appendMsg(msg,'u');
  const tid=showTyping();
  try{
    const meals=DB.get('m:'+U.email)||[];
    const wks=DB.get('k:'+U.email)||[];
    const tod=hoje();
    const todK=meals.filter(m=>m.date===tod).reduce((s,m)=>s+(+m.kcal||0),0);
    const weekW=wks.filter(w=>w.date>=segunda()).length;
    const ctx=`Você é o assistente do Evoluai. Usuário: ${U.nome}, ${U.idade}a, ${U.peso}kg→meta ${U.metaPeso}kg, objetivo: ${U.objetivo}, nível: ${U.nivel}, local: ${U.local}. Hoje: ${todK}kcal. Treinos esta semana: ${weekW}.`;
    const txt=await callAI(`${ctx}\nPergunta: ${msg}\nResponda em português, max 180 palavras, use emojis, seja motivador.`,1000);
    removeTyping(tid); appendMsg(txt,'a');
  } catch(e){ removeTyping(tid); appendMsg('Ops! Erro técnico. Tente novamente 🛠️','a'); }
}

function sendQ(m){
  if(U.plan!=='pro'){openMov('mPay');return;}
  document.getElementById('cinp').value=m; sendChat();
}

function appendMsg(text,from){
  const msgs=document.getElementById('chatMsgs');
  const now=new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
  msgs.insertAdjacentHTML('beforeend',from==='u'
    ?`<div class="msg msgU"><div class="msgB">${esc(text)}</div><div class="msgT">${now}</div></div>`
    :`<div class="msg msgA"><div class="aiAv">RI</div><div class="msgB">${text}</div><div class="msgT">${now}</div></div>`);
  msgs.scrollTop=msgs.scrollHeight;
}

function showTyping(){
  const msgs=document.getElementById('chatMsgs');
  const id='ty'+Date.now();
  msgs.insertAdjacentHTML('beforeend',
    `<div class="msg msgA" id="${id}"><div class="aiAv">RI</div>
     <div class="msgB"><div class="typing"><span></span><span></span><span></span></div></div></div>`);
  msgs.scrollTop=msgs.scrollHeight; return id;
}
function removeTyping(id){document.getElementById(id)?.remove();}
function esc(t){
  return String(t)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#x27;')
    .replace(/\//g,'&#x2F;');
}
// Sanitização leve para dados da API
function san(t){return String(t||'').replace(/<script[\s\S]*?<\/script>/gi,'').replace(/on\w+\s*=/gi,'').slice(0,2000);}

